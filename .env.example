# ─────────────────────────────────────────────────────────────
# Contact form (Resend) — set these in your Vercel project's
# Environment Variables. They are used by the serverless function
# at /api/contact and are NEVER exposed to the browser.
# Sign up at https://resend.com and create an API key.
# ─────────────────────────────────────────────────────────────

# Required for the contact form to actually send email:
RESEND_API_KEY=

# Optional overrides:
# Where contact messages are delivered (defaults to krishnamathur008@gmail.com):
CONTACT_TO_EMAIL=
# A verified Resend sender. Until you verify a domain in Resend, leave this
# blank to use Resend's shared onboarding sender. Example once verified:
#   CONTACT_FROM_EMAIL=Portfolio <hello@yourdomain.com>
CONTACT_FROM_EMAIL=
